# Site REJCC (Next.js) — variables d'environnement

# URL publique de l'API Laravel (rejcc-api), une fois hébergée.
# Si définie, les routes /api/* du site relaient vers le backend (persistance MySQL,
# paiement, e-mails). Si absente, le site fonctionne en autonomie (validation + accusé).
# Exemple : https://api.rejcc.ci
# REJCC_API_URL=

# URL publique de l'API Laravel pour l'ESPACE MEMBRE (appels côté navigateur).
# Si absente, l'espace membre affiche « bientôt disponible ».
# En dev : http://127.0.0.1:8000 (dans .env.local). En prod : l'URL du backend hébergé.
# NEXT_PUBLIC_API_URL=
